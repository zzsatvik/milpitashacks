# =============================================================================
# OpenAI (server-side only — used by apps/api)
# =============================================================================
OPENAI_API_KEY=sk-...

# Set to "true" to skip OpenAI and use demo mock data
# VITE_USE_MOCK=true

# =============================================================================
# InsForge (auth + database) — get these from your InsForge project dashboard
# =============================================================================
# Project URL, e.g. https://your-app.us-east.insforge.app
VITE_INSFORGE_BASE_URL=https://your-app.us-east.insforge.app

# Anonymous/public key — run: npx @insforge/cli secrets get ANON_KEY
VITE_INSFORGE_ANON_KEY=your-anon-key-here

# Optional: override API URL for lawn analysis (defaults to vite proxy → :3001)
# VITE_API_URL=http://localhost:3001
