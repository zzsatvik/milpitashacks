{
  "name": "terraview",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:web": "npm run dev --workspace=@terraview/web",
    "dev:api": "npm run dev --workspace=@terraview/api",
    "dev:all": "concurrently -n web,api -c green,blue \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm run build --workspace=@terraview/web",
    "preview": "npm run preview --workspace=@terraview/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
